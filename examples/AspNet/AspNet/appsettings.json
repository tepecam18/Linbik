{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Debug",
      "Microsoft.AspNetCore.Authentication": "Trace",
      "Microsoft.AspNetCore.Authorization": "Trace"
    }
  },
  "AllowedHosts": "*",

  "Linbik": {
    "LinbikUrl": "https://localhost:7182",
    // "LinbikUrl": "https://dev.linbik.com",
    "ServiceId": "411acf3c-d625-4630-8e92-959e8bc9cda5",
    "ClientId": "94dce588-9de3-4c0c-b809-064f12a88b18",
    "ApiKey": "lnbk_NTJIhaxHUaBQulPFjCP0d1zAQ1ZgUKmx",
    "AuthorizationEndpoint": "/auth",
    "TokenEndpoint": "/auth/token",
    "RefreshEndpoint": "/auth/refresh",
    "CallbackPath": "/linbik/callback",

    "JwtAuth": {
      "SecretKey": "LinbikExampleSecretKeyAtLeast32CharsLong!",
      "JwtIssuer": "linbik-example",
      "JwtAudience": "linbik-example-client"
    },

    "Resilience": {
      "Enabled": true,
      "MaxRetryAttempts": 3,
      "RetryDelayMs": 1000,
      "MaxRetryDelayMs": 30000,
      "CircuitBreakerEnabled": true,
      "CircuitBreakerFailureThreshold": 5,
      "CircuitBreakerSamplingDurationSeconds": 30,
      "CircuitBreakerDurationSeconds": 30,
      "TimeoutSeconds": 30,
      "AttemptTimeoutSeconds": 10
    },

    "RateLimit": {
      "Enabled": true,
      "PolicyName": "LinbikAuth",
      "PermitLimit": 10,
      "WindowSeconds": 60,
      "QueueLimit": 0,
      "UseSlidingWindow": false,
      "SegmentsPerWindow": 4
    },

    "Audit": {
      "Enabled": true,
      "LogSuccessfulOperations": true,
      "LogFailedOperations": true,
      "IncludeUserAgent": true,
      "IncludeIpAddress": true,
      "MaskSensitiveData": true
    },

    "YARP": {
      "IntegrationTokenCookiePrefix": "integration_",
      "IntegrationServices": {
        "payment-gateway": {
          "PackageName": "payment-gateway",
          "BaseUrl": "https://payment.example.com",
          "ServiceId": "00000000-0000-0000-0000-000000000001",
          "TimeoutSeconds": 30,
          "StripPackagePrefix": true
        },
        "survey-service": {
          "PackageName": "survey-service",
          "BaseUrl": "https://survey.example.com",
          "ServiceId": "00000000-0000-0000-0000-000000000002",
          "TimeoutSeconds": 30,
          "StripPackagePrefix": true
        }
      }
    },
    "Yarp": [
      {
        "RouteId": "payment-route",
        "ClusterId": "payment-cluster",
        "PrefixPath": "api/payment",
        "ServicePackageName": "payment-gateway",
        "Clusters": [
          {
            "Name": "payment1",
            "Address": "https://payment.example.com"
          }
        ]
      },
      {
        "RouteId": "survey-route",
        "ClusterId": "survey-cluster",
        "PrefixPath": "api/survey",
        "ServicePackageName": "survey-service",
        "Clusters": [
          {
            "Name": "survey1",
            "Address": "https://survey.example.com"
          }
        ]
      }
    ]
  }
}

